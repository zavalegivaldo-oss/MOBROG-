body{
    margin:0;
    font-family:Arial;
    background:#f4f6f8;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.box{
    background:white;
    padding:30px;
    border-radius:12px;
    width:320px;
    box-shadow:0 4px 15px rgba(0,0,0,0.1);
}

input{
    width:100%;
    padding:14px;
    margin-top:15px;
}

button{
    width:100%;
    padding:15px;
    background:#e21a22;
    color:white;
    border:none;
    margin-top:15px;
    cursor:pointer;
}

.modal{
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.7);
    display:none;
    justify-content:center;
    align-items:center;
}

.modal-content{
    background:white;
    padding:30px;
    border-radius:12px;
    text-align:center;
}
